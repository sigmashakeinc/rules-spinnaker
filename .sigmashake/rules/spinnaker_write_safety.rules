# spinnaker_write_safety.rules
# Technology: spinnaker | Capability: write

rule spinnaker-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_spinnaker_PATTERN"
  MESSAGE "Blocked an unsafe pattern in spinnaker. Use the recommended best practices for 2025/2026."
}

rule spinnaker-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_spinnaker_API"
  MESSAGE "You are using an outdated API for spinnaker. Please upgrade to the newer API."
}
